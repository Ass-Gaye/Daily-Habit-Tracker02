rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'dewsangam1@gmail.com';
    }

    function isUserAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isUserAdmin();
    }

    // Entity Validations
    function isValidHabit(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 100 &&
             (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 500)) &&
             (!data.keys().hasAny(['whyItMatters']) || (data.whyItMatters is string && data.whyItMatters.size() <= 500)) &&
             (!data.keys().hasAny(['benefits']) || (data.benefits is string && data.benefits.size() <= 500)) &&
             data.category is string && data.category.size() <= 50 &&
             data.createdBy is string && data.createdBy.size() <= 128;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 100)) &&
             (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100)) &&
             data.currentStreak is int && data.currentStreak >= 0 &&
             data.longestStreak is int && data.longestStreak >= 0 &&
             (!data.keys().hasAny(['lastActiveDate']) || (data.lastActiveDate is string && data.lastActiveDate.size() <= 10)) &&
             data.achievements is list && data.achievements.size() <= 50 &&
             data.weeklyGoal is int &&
             (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool);
    }

    function isValidWeeklyProgress(data) {
      return data.id is string && data.id.size() <= 10 &&
             data.completions is map &&
             data.notes is map;
    }

    // Habits collection rules (Global collection)
    match /habits/{habitId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidId(habitId) && isValidHabit(incoming()) && (isAdmin() || incoming().createdBy == request.auth.uid);
      allow delete: if isSignedIn() && isValidId(habitId) && (isAdmin() || existing().createdBy == request.auth.uid);
    }

    // Users profiles rules
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if false;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        !incoming().diff(existing()).affectedKeys().hasAny(['isAdmin']) || isAdmin()
      );
      allow delete: if isAdmin() || isOwner(userId);
    }

    // User's weekly progress nested subcollection rules
    match /users/{userId}/progress/{weekId} {
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create, update: if isOwner(userId) && isValidId(weekId) && isValidWeeklyProgress(incoming());
      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
